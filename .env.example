# 复制本文件为 .env 并填入你自己的密钥 / Copy to .env and fill in your own key.
# 本界面读取 TradingAgents 的同一套 .env 配置。
# This UI reads the same .env that TradingAgents itself uses.

# ===== 选择一个 LLM 提供商，填它的 key =====
# Pick ONE provider and set its API key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=          # MiniMax 国际站 / global (api.minimax.io)
MINIMAX_CN_API_KEY=       # MiniMax 中国站 / China (api.minimaxi.com)
OPENROUTER_API_KEY=

# ===== 预设配置（跳过交互、直接生效）=====
# Provider/model presets. Example below uses MiniMax China.
TRADINGAGENTS_LLM_PROVIDER=minimax-cn
TRADINGAGENTS_LLM_BACKEND_URL=https://api.minimaxi.com/v1
TRADINGAGENTS_DEEP_THINK_LLM=MiniMax-M3
TRADINGAGENTS_QUICK_THINK_LLM=MiniMax-M2.7-highspeed
TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
TRADINGAGENTS_TEMPERATURE=0.0
